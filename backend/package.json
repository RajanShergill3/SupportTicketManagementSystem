{
  "name": "support-ticket-management-system-api",
  "version": "1.0.0",
  "description": "Backend API for the Support Ticket Management System",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "seed": "tsx src/database/seed.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "support-tickets",
    "express",
    "typescript",
    "mongodb"
  ],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "mongoose": "^8.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.1",
    "@types/supertest": "^7.2.1",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "prettier": "^3.5.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1"
  }
}
